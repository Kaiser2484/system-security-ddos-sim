# .env – Docker Compose environment variables
#
# Điều khiển Nginx config (chuyển đổi Phase):
#   Phase 1 & 2 (không có defense): NGINX_CONF=nginx.conf
#   Phase 3     (có defense):       NGINX_CONF=nginx_defended.conf
#
# Sau khi thay đổi, chạy:  docker-compose up -d   (nginx sẽ reload config mới)

NGINX_CONF=nginx_defended.conf
