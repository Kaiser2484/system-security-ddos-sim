{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "text", "name": "Text", "version": "" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "DDoS Simulation – Phase 1, 2 & 3: Attack & Defense Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 20,
      "title": "🔴 Live Status — Top-Level KPIs",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "red", "value": 100 }
          ]},
          "unit": "reqps",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "🌐 Total Request Rate (req/s)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(flask_http_request_total[15s]))",
          "legendFormat": "RPS",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.3 },
            { "color": "red", "value": 1.0 }
          ]},
          "unit": "s",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "⏱ Avg Response Time",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(flask_http_request_duration_seconds_sum{path='/api/data'}[15s]) / rate(flask_http_request_duration_seconds_count{path='/api/data'}[15s])",
          "legendFormat": "Avg Latency",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]},
          "unit": "reqps",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "❌ Error Rate (5xx/s)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(flask_http_request_total{status=~'5..'}[15s]))",
          "legendFormat": "5xx/s",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "green", "value": 95 }
          ]},
          "unit": "percent",
          "min": 0, "max": 100,
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "🚦 HTTP 200 Success Rate",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(flask_http_request_total{status='200'}[15s])) / sum(rate(flask_http_request_total[15s])) * 100",
          "legendFormat": "Success %",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 21,
      "title": "📈 Request Traffic & Latency Analysis",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false, "axisColorMode": "text", "axisLabel": "req/s",
            "axisPlacement": "auto", "barAlignment": 0, "drawStyle": "line",
            "fillOpacity": 20, "gradientMode": "opacity", "lineInterpolation": "smooth",
            "lineWidth": 2, "pointSize": 4, "scaleDistribution": { "type": "linear" },
            "showPoints": "never", "spanNulls": false,
            "thresholdsStyle": { "mode": "line+area" }
          },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "transparent", "value": null },
            { "color": "rgba(255, 0, 0, 0.1)", "value": 50 }
          ]},
          "unit": "reqps"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "HTTP 200" }, "properties": [ { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } } ] },
          { "matcher": { "id": "byRegexp", "options": "HTTP 5.." }, "properties": [ { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } } ] },
          { "matcher": { "id": "byRegexp", "options": "HTTP 4.." }, "properties": [ { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "HTTP 429" }, "properties": [ { "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } } ] }
        ]
      },
      "gridPos": { "h": 9, "w": 14, "x": 0, "y": 7 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["last", "max", "mean"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "📈 Request Rate by HTTP Status (Attack shows spike + 5xx)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(status) (rate(flask_http_request_total[15s]))",
          "legendFormat": "HTTP {{status}}",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false, "axisColorMode": "text", "axisLabel": "seconds",
            "axisPlacement": "auto", "barAlignment": 0, "drawStyle": "line",
            "fillOpacity": 15, "gradientMode": "opacity", "lineInterpolation": "smooth",
            "lineWidth": 2, "pointSize": 4, "scaleDistribution": { "type": "linear" },
            "showPoints": "never", "spanNulls": false
          },
          "unit": "s"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p50 (median)" }, "properties": [ { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "p95" }, "properties": [ { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "p99" }, "properties": [ { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } } ] }
        ]
      },
      "gridPos": { "h": 9, "w": 10, "x": 14, "y": 7 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["last", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "⏱ Latency Percentiles p50 / p95 / p99 (explodes under attack)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(flask_http_request_duration_seconds_bucket{path='/api/data'}[15s])) by (le))",
          "legendFormat": "p50 (median)",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(flask_http_request_duration_seconds_bucket{path='/api/data'}[15s])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(flask_http_request_duration_seconds_bucket{path='/api/data'}[15s])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 22,
      "title": "🔗 Nginx Connection Layer (Slowloris attack shows here)",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false, "axisColorMode": "text", "axisLabel": "connections",
            "axisPlacement": "auto", "barAlignment": 0, "drawStyle": "line",
            "fillOpacity": 20, "gradientMode": "none", "lineInterpolation": "smooth",
            "lineWidth": 2, "pointSize": 4, "scaleDistribution": { "type": "linear" },
            "showPoints": "never", "spanNulls": false,
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "transparent", "value": null },
            { "color": "red", "value": 800 }
          ]},
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Active" }, "properties": [ { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "Waiting (Slowloris target)" }, "properties": [ { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "Reading+Writing" }, "properties": [ { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } } ] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["last", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "🔗 Nginx Connections (Waiting spikes = Slowloris effect)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "nginx_connections_active",
          "legendFormat": "Active",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "nginx_connections_waiting",
          "legendFormat": "Waiting (Slowloris target)",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "nginx_connections_reading + nginx_connections_writing",
          "legendFormat": "Reading+Writing",
          "refId": "C"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false, "axisColorMode": "text", "axisLabel": "req/s",
            "axisPlacement": "auto", "barAlignment": 0, "drawStyle": "bars",
            "fillOpacity": 70, "gradientMode": "none", "lineInterpolation": "linear",
            "lineWidth": 1, "pointSize": 4, "scaleDistribution": { "type": "linear" },
            "showPoints": "never", "spanNulls": false
          },
          "unit": "reqps"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Nginx req/s (HTTP Flood target)" }, "properties": [ { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } } ] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "id": 8,
      "options": {
        "legend": { "calcs": ["last", "max", "mean"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "🌊 Nginx Total Throughput (HTTP Flood → massive spike)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(nginx_http_requests_total[15s])",
          "legendFormat": "Nginx req/s (HTTP Flood target)",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 23,
      "title": "🛡️ Phase Comparison — Gauge Overview",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 30 },
            { "color": "orange", "value": 100 },
            { "color": "red", "value": 300 }
          ]},
          "unit": "reqps",
          "min": 0, "max": 500
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 26 },
      "id": 9,
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showThresholdLabels": true, "showThresholdMarkers": true, "text": {} },
      "title": "⚡ Current Attack Intensity (RPS gauge)",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(flask_http_request_total[15s]))",
          "legendFormat": "Total RPS",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.5 },
            { "color": "red", "value": 2.0 }
          ]},
          "unit": "s",
          "min": 0, "max": 10
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 26 },
      "id": 10,
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showThresholdLabels": true, "showThresholdMarkers": true, "text": {} },
      "title": "🔥 p99 Latency Gauge (should stay < 500ms)",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(flask_http_request_duration_seconds_bucket{path='/api/data'}[15s])) by (le))",
          "legendFormat": "p99",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "red", "value": 200 }
          ]},
          "unit": "short",
          "min": 0, "max": 1024
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 26 },
      "id": 11,
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showThresholdLabels": true, "showThresholdMarkers": true, "text": {} },
      "title": "🔗 Active Connections Gauge (Slowloris fills this up)",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "nginx_connections_active",
          "legendFormat": "Active Connections",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "id": 24,
      "title": "🛡️ Phase 3: Defense Effectiveness (429 = Requests Blocked by Rate Limit)",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "purple", "value": 1 }
          ]},
          "unit": "reqps",
          "mappings": [
            { "type": "value", "options": { "0": { "text": "No attack / Not defended", "color": "green" } } }
          ]
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 35 },
      "id": 12,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "🚫 Rate-Limited Requests (429/s) — Purple = Defense Working",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "clamp_min(rate(nginx_http_requests_total[15s]) - scalar(sum(rate(flask_http_request_total[15s]))), 0)",
          "legendFormat": "Blocked/s",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 30 },
            { "color": "green", "value": 70 }
          ]},
          "unit": "percent",
          "min": 0, "max": 100,
          "mappings": [
            { "type": "special", "options": { "match": "null", "result": { "text": "No data", "color": "gray" } } }
          ]
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 35 },
      "id": 13,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "🛡️ Defense Effectiveness — % Attack Blocked (429 / Total)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "clamp_min(rate(nginx_http_requests_total[15s]) - scalar(sum(rate(flask_http_request_total[15s]))), 0) / rate(nginx_http_requests_total[15s]) * 100",
          "legendFormat": "Blocked %",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false, "axisColorMode": "text", "axisLabel": "req/s",
            "axisPlacement": "auto", "barAlignment": 0, "drawStyle": "line",
            "fillOpacity": 20, "gradientMode": "opacity", "lineInterpolation": "smooth",
            "lineWidth": 2, "pointSize": 4, "scaleDistribution": { "type": "linear" },
            "showPoints": "never", "spanNulls": false
          },
          "unit": "reqps"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "HTTP 200 (passed)" }, "properties": [ { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "HTTP 429 (blocked)" }, "properties": [ { "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } } ] },
          { "matcher": { "id": "byRegexp", "options": "HTTP 5.." }, "properties": [ { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } } ] }
        ]
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 35 },
      "id": 14,
      "options": {
        "legend": { "calcs": ["last", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "📊 Pass vs Block Rate Timeline (Phase 3 Defense)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(flask_http_request_total{status='200'}[15s]))",
          "legendFormat": "Passed (200)",
          "refId": "A"
        },
